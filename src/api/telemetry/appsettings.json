{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Telemetry": {
    "PrometheusUrl": "http://kube-prometheus-stack-prometheus.monitoring.svc:9090",
    "ScrapingIntervalSeconds": 15,
    "OutputMode": "local",
    "OutputPath": "/app/data"
  },
  "EventHub": {
    "FullyQualifiedNamespace": "",
    "EventHubName": "telemetry-events"
  }
}